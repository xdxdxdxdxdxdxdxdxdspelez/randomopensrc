local Library = loadstring(game:HttpGet('https://raw.githubusercontent.com/wrexlua/SOLIXHUB/refs/heads/retard/SolixUI.lua'))()
local Window = Library:Window({
    Name = 'My Hub',
    Size = UDim2.new(0, 770, 0, 526),
    FadeSpeed = 0.25,
})

local function PlayNotifSound()
    pcall(function()
        local Event = game:GetService('ReplicatedStorage').Packages._Index['littensy_remo@1.5.3'].remo.container.SoundManager_Play

        firesignal(Event.OnClientEvent, 'NOTIF1')
    end)
end

local MainPage = Window:Page({
    Name = 'Main',
    Columns = 2,
})
local MainSection = MainPage:Section({
    Name = 'Main',
    Side = 1,
})
local MainButtons = MainSection:Button()

MainButtons:Add('Treadmill', function()
    local success, err = pcall(function()
        local Event = game:GetService('ReplicatedStorage').Remotes.PlacePersonalTreadmill

        Event:InvokeServer()
    end)

    if not success then
        warn('Treadmill error:', err)
        Library:Notification('Error', 'Failed to place treadmill.', 3)
    end
end, false, 'Places a personal treadmill')

local VisualsPage = Window:Page({
    Name = 'Visuals',
    Columns = 2,
})
local VisualsSection = VisualsPage:Section({
    Name = 'Message Announce',
    Side = 1,
})
local AnnounceData = {
    PlayerId = '',
    Message = '',
    SenderName = '',
    IsOwner = false,
}

VisualsSection:Textbox({
    Name = 'Player ID',
    Flag = 'AnnouncePlayerId',
    Default = '',
    Placeholder = 'Enter Sender UserId...',
    Callback = function(Value)
        AnnounceData.PlayerId = Value
    end,
})
VisualsSection:Textbox({
    Name = 'Message',
    Flag = 'AnnounceMessage',
    Default = '',
    Placeholder = 'Enter announcement text...',
    Callback = function(Value)
        AnnounceData.Message = Value
    end,
})
VisualsSection:Textbox({
    Name = 'Sender Name',
    Flag = 'AnnounceSenderName',
    Default = '',
    Placeholder = 'Enter sender name...',
    Callback = function(Value)
        AnnounceData.SenderName = Value
    end,
})
VisualsSection:Toggle({
    Name = 'Is Owner',
    Flag = 'AnnounceIsOwner',
    Default = false,
    Tooltip = 'Shows the owner badge/tag on the announcement',
    Callback = function(Value)
        AnnounceData.IsOwner = Value
    end,
})

local AnnounceButtons = VisualsSection:Button()

AnnounceButtons:Add('Announce', function()
    local PlayerId = tonumber(AnnounceData.PlayerId)

    if not PlayerId then
        Library:Notification('Error', 'Please enter a valid Player ID.', 3)

        return
    end
    if AnnounceData.Message == '' then
        Library:Notification('Error', 'Please enter a message.', 3)

        return
    end
    if AnnounceData.SenderName == '' then
        Library:Notification('Error', 'Please enter a sender name.', 3)

        return
    end

    local success, err = pcall(function()
        local Event = game:GetService('ReplicatedStorage').Remotes.AdminAnnounce

        firesignal(Event.OnClientEvent, {
            text = AnnounceData.Message,
            isOwner = AnnounceData.IsOwner,
            senderUserId = PlayerId,
            senderName = AnnounceData.SenderName,
        })
    end)

    if not success then
        warn('Announce error:', err)
        Library:Notification('Error', 'Failed to send announcement.', 3)

        return
    end

    PlayNotifSound()
end, false, 'Sends a fake admin announcement')

