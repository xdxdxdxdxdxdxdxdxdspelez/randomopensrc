local MultiplierButtons = SpooferSection:Button()

MultiplierButtons:Add('Spoof Multiplier', function()
    local XPMult = tonumber(MultiplierData.XPMult)
    local XPDuration = tonumber(MultiplierData.XPDuration)
    local WinsMult = tonumber(MultiplierData.WinsMult)
    local WinsDuration = tonumber(MultiplierData.WinsDuration)

    if not XPMult then
        Library:Notification('Error', 'Please enter a valid XP multiplier.', 3)

        return
    end
    if not XPDuration then
        Library:Notification('Error', 'Please enter a valid XP duration.', 3)

        return
    end
    if not WinsMult then
        Library:Notification('Error', 'Please enter a valid Wins multiplier.', 3)

        return
    end
    if not WinsDuration then
        Library:Notification('Error', 'Please enter a valid Wins duration.', 3)

        return
    end

    local success, err = pcall(function()
        local Event = game:GetService('ReplicatedStorage').Packages._Index['littensy_remo@1.5.3'].remo.container.BonusUpdate

        firesignal(Event.OnClientEvent, {
            globalBonuses = {
                AdminAbuse = {
                    XP = {
                        endTime = tick() + XPDuration,
                        mult = XPMult,
                    },
                    Wins = {
                        endTime = tick() + WinsDuration,
                        mult = WinsMult,
                    },
                },
            },
            playerBonuses = {},
            serverBonuses = {},
        })
    end)

    if not success then
        warn('Multiplier Spoofer error:', err)
        Library:Notification('Error', 'Failed to spoof multiplier.', 3)

        return
    end

    Library:Notification('Success', 'Multipliers spoofed!', 3)
    PlayNotifSound()
end, false, 'Spoofs XP and Wins multipliers')
