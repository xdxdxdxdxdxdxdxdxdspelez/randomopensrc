Tab:CreateToggle({
    Name = 'Auto Collect Cash',
    CurrentValue = false,
    Flag = 'ToggleCollect',
    Callback = function(Value)
        autoCollect = Value

        if autoCollect then
            collectThread = task.spawn(function()
                while autoCollect do
                    pcall(function()
                        local character = LocalPlayer.Character
                        local rootPart = character and (character:FindFirstChild('HumanoidRootPart') or character:FindFirstChild('Torso'))

                        if rootPart and autoCollect then
                            for _, object in ipairs(workspace:GetDescendants())do
                                if not autoCollect then
                                    break
                                end
                                if object:IsA('BasePart') and (object.Name == 'CashDrop' or object.Name == 'CashDrops') then
                                    local oldCFrame = rootPart.CFrame

                                    if autoCollect then
                                        rootPart.CFrame = object.CFrame
                                        rootPart.CFrame = oldCFrame
                                    end
                                end
                            end
                        end
                    end)
                    task.wait(0.3)
                end
            end)
        else
            if collectThread then
                task.cancel(collectThread)

                collectThread = nil
            end
        end
    end,
})
Tab:CreateToggle({
    Name = 'Auto Collect Fruit',
    CurrentValue = false,
    Flag = 'ToggleFruit',
    Callback = function(Value)
        autoFruit = Value

        if autoFruit then
            fruitThread = task.spawn(function()
                while autoFruit do
                    pcall(function()
                        local myTycoon = getMyTycoon()
                        local character = LocalPlayer.Character
                        local rootPart = character and (character:FindFirstChild('HumanoidRootPart') or character:FindFirstChild('Torso'))

                        if myTycoon and rootPart and autoFruit then
                            for _, tree in ipairs(myTycoon:GetDescendants())do
                                if not autoFruit then
                                    break
                                end
                                if tree:IsA('Model') and tree.Name == 'LemonTree' then
                                    for _, object in ipairs(tree:GetDescendants())do
                                        if not autoFruit then
                                            break
                                        end
                                        if object:IsA('BasePart') and object.Name == 'Fruit' then
                                            local oldCFrame = rootPart.CFrame

                                            if autoFruit then
                                                rootPart.CFrame = object.CFrame

                                                local clicker = object:FindFirstChild('ClickPart') or object:FindFirstChildOfClass('ClickDetector') or object.Parent:FindFirstChild('ClickPart')

                                                if clicker and autoFruit then
                                                    if clicker:IsA('ClickDetector') then
                                                        fireclickdetector(clicker)
                                                    elseif clicker:FindFirstChildOfClass('ClickDetector') then
                                                        fireclickdetector(clicker:FindFirstChildOfClass('ClickDetector'))
                                                    end
                                                end

                                                rootPart.CFrame = oldCFrame
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end)
                    task.wait(0.4)
                end
            end)
        else
            if fruitThread then
                task.cancel(fruitThread)

                fruitThread = nil
            end
        end
    end,
})
