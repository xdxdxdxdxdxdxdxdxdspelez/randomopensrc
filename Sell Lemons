local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
    Name = 'spelhub',
    LoadingTitle = 'Sell Lemons',
    LoadingSubtitle = 'By Spel',
    ConfigurationSaving = {Enabled = false},
    KeySystem = false,
})
local Tab = Window:CreateTab('Main Features', nil)
local autoUpgrade = false
local autoPurchase = false
local autoCollect = false
local autoFruit = false
local autoRebirth = false
local autoCollectStand = false
local upgradeThread = nil
local purchaseThread = nil
local collectThread = nil
local fruitThread = nil
local rebirthThread = nil
local collectStandThread = nil
local LocalPlayer = game:GetService('Players').LocalPlayer

local function getMyTycoon()
    for i = 1, 10 do
        local tycoon = workspace:FindFirstChild('Tycoon' .. i)

        if tycoon then
            local ownerValue = tycoon:FindFirstChild('Owner')

            if ownerValue then
                if ownerValue.Value == LocalPlayer or ownerValue.Value == LocalPlayer.Name or tostring(ownerValue.Value) == LocalPlayer.Name then
                    return tycoon
                end
            end

            local playerValue = tycoon:FindFirstChild('Player')

            if playerValue then
                if playerValue.Value == LocalPlayer or playerValue.Value == LocalPlayer.Name then
                    return tycoon
                end
            end
        end
    end

    return nil
end

Tab:CreateToggle({
    Name = 'Auto Upgrade',
    CurrentValue = false,
    Flag = 'ToggleUpgrade',
    Callback = function(Value)
        autoUpgrade = Value

        if autoUpgrade then
            upgradeThread = task.spawn(function()
                while autoUpgrade do
                    pcall(function()
                        local myTycoon = getMyTycoon()

                        if myTycoon and autoUpgrade then
                            for _, object in ipairs(myTycoon:GetDescendants())do
                                if not autoUpgrade then
                                    break
                                end
                                if object:IsA('RemoteFunction') and object.Name == 'Upgrade' then
                                    task.spawn(function()
                                        if autoUpgrade then
                                            object:InvokeServer(1)
                                        end
                                    end)
                                end
                            end
                        end
                    end)
                    task.wait(0.01)
                end
            end)
        else
            if upgradeThread then
                task.cancel(upgradeThread)

                upgradeThread = nil
            end
        end
    end,
})
