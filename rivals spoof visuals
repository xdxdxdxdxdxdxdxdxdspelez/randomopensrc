local function SpoofLeaderboard()
    local UserId = LeaderboardData.UserId
    local Value = tonumber(LeaderboardData.Value)
    local Position = tonumber(LeaderboardData.Position)

    if not UserId or UserId == '' then
        Library:Notify('Enter a User ID.', 3)

        return
    end
    if not Value then
        Library:Notify('Enter a valid value.', 3)

        return
    end
    if not Position or Position < 1 then
        Position = 1
    end

    local ok = pcall(function()
        local currentSerial = CachedLeaderboards[LeaderboardData.Name]
        local PlayersList = {}

        if currentSerial and currentSerial.Players then
            for _, entry in ipairs(currentSerial.Players)do
                table.insert(PlayersList, {
                    key = entry.key,
                    value = entry.value,
                })
            end
        end

        for i = #PlayersList, 1, -1 do
            if PlayersList[i].key == tostring(UserId) then
                table.remove(PlayersList, i)
            end
        end

        table.insert(PlayersList, Position, {
            key = tostring(UserId),
            value = Value,
        })
        firesignal(ReplicatedStorage.Remotes.Misc.UpdateLeaderboard.OnClientEvent, {
            Name = LeaderboardData.Name,
            Players = PlayersList,
        })
    end)

    if ok then
        Library:Notify('Spoofed at pos ' .. Position .. '!', 3)
    else
        Library:Notify('Spoof failed.', 3)
    end
end
local function RefreshLeaderboard()
    pcall(function()
        firesignal(ReplicatedStorage.Remotes.Misc.LeaderboardRefreshed.OnClientEvent, LeaderboardData.Name)
    end)
    Library:Notify(LeaderboardData.Name .. ' refreshed!', 3)
end

