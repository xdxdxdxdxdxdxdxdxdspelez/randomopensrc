            Player = PlayerId,
            Frame = GetNil('Template', '0_1519774'),
            Length = Length,
            StartTime = tick(),
            FromServer = true,
        })
    end)

    if not success then
        warn('Kill Notification error:', err)
        Library:Notification('Error', 'Failed to fire kill notification.', 3)

